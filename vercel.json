{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 30,
        "includeFiles": ["src/**", "app.py", "static/**"]
      }
    },
    {
      "src": "api/notify.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 30,
        "includeFiles": ["src/**"]
      }
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/api/ping",
      "dest": "/api/index.py"
    },
    {
      "src": "/api/notify(.*)",
      "dest": "/api/notify.py"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ],
  "crons": [
    { "path": "/api/notify?type=morning",   "schedule": "0 5 * * *"  },
    { "path": "/api/notify?type=midday",    "schedule": "0 7 * * *"  },
    { "path": "/api/notify?type=afternoon", "schedule": "0 10 * * *" },
    { "path": "/api/notify?type=evening",   "schedule": "0 13 * * *" },
    { "path": "/api/notify?type=night",     "schedule": "0 16 * * *" },
    { "path": "/api/notify?type=final",     "schedule": "30 18 * * *"}
  ]
}
